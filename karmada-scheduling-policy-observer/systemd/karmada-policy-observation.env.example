# Copy to /etc/karmada-policy-observation.env. Keep this file root-readable only.
# The service account needs read-only access to all kubeconfig files below.
KUBECTL_BIN=/usr/local/bin/kubectl
KARMADA_KUBECONFIG=/etc/karmada-policy-observation/karmada.yaml
CLUSTER_001_KUBECONFIG=/etc/karmada-policy-observation/001.yaml
CLUSTER_WLCB_KUBECONFIG=/etc/karmada-policy-observation/wlcb.yaml
RUNTIME_DIR=/var/lib/karmada-policy-observation
